<definitions xmlns="http://schemas.xmlsoap.org/wsdl/"
             xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
             xmlns:tns="http://pagopa.gov.it/pa"
             xmlns:xsd="http://www.w3.org/2001/XMLSchema"
             targetNamespace="http://pagopa.gov.it/pa">

  <documentation>Servizio PagoPA per la gestione dei pagamenti in ambiente pubblico.</documentation>

  <!-- Definizione dei tipi XSD -->
  <types>
    <xsd:schema>
      <xsd:import namespace="http://pagopa.gov.it/schema" schemaLocation="pagopa_types.xsd"/>
    </xsd:schema>
  </types>

  <!-- Messaggio per la richiesta di pagamento -->
  <message name="InitiatePaymentRequest">
    <part name="paymentId" type="xsd:string">
      <documentation>Identificativo univoco del pagamento</documentation>
    </part>
    <part name="amount" type="xsd:decimal">
      <documentation>Importo del pagamento</documentation>
    </part>
  </message>

  <!-- Messaggio per la risposta di pagamento -->
  <message name="InitiatePaymentResponse">
    <part name="status" type="xsd:string">
      <documentation>Stato della transazione di pagamento</documentation>
    </part>
    <part name="confirmationCode" type="xsd:string">
      <documentation>Codice di conferma dell'avvenuto pagamento</documentation>
    </part>
  </message>

  <!-- Definizione del portType che descrive le operazioni -->
  <portType name="PaymentServicePortType">
    <operation name="InitiatePayment">
      <documentation>Avvia un pagamento basato su un identificativo e un importo.</documentation>
      <input message="tns:InitiatePaymentRequest"/>
      <output message="tns:InitiatePaymentResponse"/>
    </operation>
  </portType>

  <!-- Binding SOAP per il portType -->
  <binding name="PaymentServiceBinding" type="tns:PaymentServicePortType">
    <soap:binding style="document" transport="http://schemas.xmlsoap.org/soap/http"/>
    
    <operation name="InitiatePayment">
      <soap:operation soapAction="http://pagopa.gov.it/InitiatePayment"/>
      <input>
        <soap:body use="literal"/>
      </input>
      <output>
        <soap:body use="literal"/>
      </output>
    </operation>
  </binding>

  <!-- Definizione del servizio con il binding -->
  <service name="PaymentService">
    <documentation>Servizio web per la gestione dei pagamenti tramite PagoPA.</documentation>
    <port name="PaymentServicePort" binding="tns:PaymentServiceBinding">
      <soap:address location="http://pagopa.gov.it/paymentService"/>
    </port>
  </service>
</definitions>
